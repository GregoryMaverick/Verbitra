# Network
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
API_PUBLIC_URL=http://localhost:4000

# Database
DATABASE_URL=postgres://verbitra:verbitra@localhost:5432/verbitra

# Auth
# Auth is still deferred in this migration. These values keep the current server code configurable.
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_EXPIRES_IN=7d
MAGIC_LINK_EXPIRES_MINUTES=15
APP_URL=https://yourdomain.app
APP_SCHEME=verbitra

# Current Replit OIDC flow, to be replaced before Play Store launch.
ISSUER_URL=https://replit.com/oidc
REPL_ID=replace-before-production

# Email for the future magic-link flow. Leave unset locally to log links during development.
SMTP_URL=
EMAIL_FROM=noreply@yourdomain.app

# AI
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
