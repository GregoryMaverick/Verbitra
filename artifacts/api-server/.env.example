# Network
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
API_PUBLIC_URL=http://localhost:4000

# Database
# Use the Supabase Postgres connection string in production. For local dev you
# can either point at the same Supabase project or run a local Postgres via
# `docker compose up -d postgres`.
DATABASE_URL=postgres://verbitra:verbitra@localhost:5432/verbitra

# Supabase Auth
# Find these in the Supabase dashboard → Project Settings → API.
#   - SUPABASE_URL: the "Project URL" (looks like https://xyzabc.supabase.co)
#   - SUPABASE_AUTH_KEY: the anon/publishable key for the same project. This is
#     enough for validating mobile access tokens via Supabase Auth.
# Use SUPABASE_SERVICE_ROLE_KEY instead only if you later add privileged admin
# operations. The service-role key bypasses Row Level Security; keep it
# server-side only and never commit it.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_AUTH_KEY=replace-with-anon-or-publishable-key

# Legacy auth knobs — kept for now because some other modules still read them.
# Safe to remove once the magic-link / JWT helpers are no longer referenced.
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_EXPIRES_IN=7d
MAGIC_LINK_EXPIRES_MINUTES=15
APP_URL=https://yourdomain.app
APP_SCHEME=verbitra

# Email (still used by the magic-link helpers in lib/email.ts).
SMTP_URL=
EMAIL_FROM=noreply@yourdomain.app

# AI
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
