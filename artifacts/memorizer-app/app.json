{
  "expo": {
    "name": "Verbitra",
    "slug": "verbitra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "verbitra",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070A"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.verbitra.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#07070A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "verbitra"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Verbitra needs camera access so you can photograph printed text for OCR."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Verbitra needs access to your photo library to let you pick images for OCR.",
          "cameraPermission": "Verbitra needs camera access so you can photograph printed text for OCR."
        }
      ],
      [
        "./plugins/with-adi-registration.js",
        {
          "snippet": "C6EBWXPLKJNR4AAAAAAAAAAAA"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c1eaccd8-b959-42f1-8cd9-8025b9a6b2aa"
      }
    },
    "owner": "gregorymaverick"
  }
}
