# API
# Must include the /api suffix because most app calls append endpoint paths like /texts.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Supabase Auth
# Get these from the Supabase dashboard → Project Settings → API.
#   - EXPO_PUBLIC_SUPABASE_URL: the "Project URL" (https://xyzabc.supabase.co)
#   - EXPO_PUBLIC_SUPABASE_ANON_KEY: the "anon" public key. This key is safe to
#     ship in the mobile app; Row Level Security in Postgres is what protects
#     user data, not the secrecy of this key.
# NEVER put the service_role key here — that is server-side only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# RevenueCat public SDK keys. These are public identifiers, not private secrets.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_key
