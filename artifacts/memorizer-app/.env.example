# API
# Must include the /api suffix because most app calls append endpoint paths like /texts.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api

# RevenueCat public SDK keys. These are public identifiers, not private secrets.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_key
